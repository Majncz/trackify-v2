# Database — pick ONE:
#
# PostgreSQL (Docker / hosted):
# DATABASE_URL="postgresql://trackify:trackify_dev@localhost:5435/trackify"
#
# SQLite file — no Docker. Then: npm run setup:sqlite && npm run dev:sqlite
DATABASE_URL="file:./prisma/dev.db"

# NextAuth — http://localhost:3002 for npm run dev:local / dev:sqlite; https behind your proxy for npm run dev
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# AI chat (@ai-sdk/anthropic — optional for chat routes)
ANTHROPIC_API_KEY=""

# Email (password reset — optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
