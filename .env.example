# Database — dev vs production
#
# LOCAL DEVELOPMENT (default): SQLite mock DB — no Postgres needed.
# Path is relative to prisma/ (file on disk: prisma/dev.db).
# npm run dev:local / dev:sqlite force this URL for the server anyway.
DATABASE_URL="file:./dev.db"
#
# PRODUCTION / STAGING / OPTIONAL PARITY: PostgreSQL (the real DB).
# Use postgresql://… on deployed hosts. Locally only if you run Docker Postgres and
# npm run dev:local:postgres, npm run stack:local, or npm run dev (HTTPS proxy flow).
# DATABASE_URL="postgresql://trackify:trackify_dev@127.0.0.1:5435/trackify"

# NextAuth — http://localhost:3002 for npm run dev:local / dev:sqlite; https behind your proxy for npm run dev
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# AI chat (@ai-sdk/anthropic — optional for chat routes)
ANTHROPIC_API_KEY=""

# Email (password reset — optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
