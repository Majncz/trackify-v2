{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trackify",
  "version": "0.1.0",
  "identifier": "co.bitterlemon.trackify",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @trackify/desktop",
    "beforeBuildCommand": "npm run build --workspace @trackify/desktop",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trackify",
        "width": 380,
        "height": 540,
        "resizable": false,
        "visible": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": []
    }
  }
}
