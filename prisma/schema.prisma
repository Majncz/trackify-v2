generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  tasks           Task[]
  passwordResets  PasswordReset[]
  conversations   Conversation[]
  activeTimers    ActiveTimer[]
  apiTokens       ApiToken[]
  taskGroups      TaskGroup[]
  billingTasks    BillingTask[]
  paymentRecords  PaymentRecord[]

  @@map("trackify_user")
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("trackify_password_reset")
}

model Task {
  id           String        @id @default(uuid())
  name         String
  hidden       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskGroupId  String?
  taskGroup    TaskGroup?    @relation(fields: [taskGroupId], references: [id], onDelete: SetNull)
  events       Event[]
  activeTimers ActiveTimer[]
  billingTask  BillingTask?

  @@index([userId, hidden])
  @@index([taskGroupId])
  @@map("trackify_task")
}

model Event {
  id               String           @id @default(uuid())
  from             DateTime         @default(now())
  to               DateTime
  name             String           @default("Time entry")
  taskId           String
  task             Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  paymentRecordId  String?
  paymentRecord    PaymentRecord?   @relation(fields: [paymentRecordId], references: [id], onDelete: SetNull)

  @@index([taskId, from])
  @@index([paymentRecordId])
  @@map("trackify_event")
}

model BillingTask {
  id             String   @id @default(uuid())
  taskId         String   @unique
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hourlyRate     Float
  currency       String   @default("CZK")
  roundingMins   Int      @default(0)
  minSessionMins Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("trackify_billing_task")
}

model PaymentRecord {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paidAt       DateTime
  note         String?
  totalAmount  Float
  totalMinutes Int
  currency     String   @default("CZK")
  events       Event[]
  createdAt    DateTime @default(now())

  @@index([userId, paidAt])
  @@map("trackify_payment_record")
}

model Conversation {
  id        String        @id @default(uuid())
  title     String?
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, updatedAt])
  @@map("trackify_conversation")
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  parts          Json?
  createdAt      DateTime     @default(now())

  @@map("trackify_chat_message")
}

model ActiveTimer {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startTime DateTime
  createdAt DateTime @default(now())

  @@map("trackify_active_timer")
}

model TaskGroup {
  id        String   @id @default(uuid())
  name      String
  color     String?  // Custom hex e.g. #4f46e5; null = derived from id in UI
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("trackify_task_group")
}

model ApiToken {
  id        String   @id @default(uuid())
  token     String   @unique
  name      String   @default("Mobile App")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastUsedAt DateTime?

  @@index([token])
  @@map("trackify_api_token")
}
